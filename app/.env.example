# Copy to .env for local development. NEVER commit a real .env.
# On AWS these values are injected at boot (DB_PASSWORD comes from Secrets Manager).
PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=app
DB_PASSWORD=changeme
DB_NAME=student_records

# Set to "false" to skip automatic table creation / seeding on startup.
RUN_MIGRATIONS=true
